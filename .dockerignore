# Docker 构建忽略文件
# 减少 Docker 构建上下文，加快构建速度

# Git 相关
.git
.gitignore
.gitattributes

# 文档和说明
*.md
LICENSE
SECURITY.md

# CI/CD 配置
.cnb.yml
.travis.yml
.gitlab-ci.yml

# 开发工具配置
.vscode
.idea
*.swp
*.swo
*~

# 构建产物
build/
dist/
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# 测试相关
*_test.go
testdata/
coverage.txt
*.test

# 临时文件
tmp/
temp/
*.tmp
*.log

# 环境配置（敏感信息）
.env
.env.*
!.env.example

# Docker 相关（避免递归）
Dockerfile*
docker-compose*.yml
.docker

# 依赖目录（Go 模块会重新下载）
vendor/
