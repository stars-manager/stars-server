# ============================================
# Docker 构建忽略文件
# ============================================
# 排除不需要复制到镜像的文件，提升构建性能和安全性

# Git 相关
.git
.gitignore
.gitattributes

# CI/CD 配置
.cnb.yml
.github
.gitlab-ci.yml
.travis.yml

# Docker 相关
Dockerfile*
docker-compose*.yml
.dockerignore

# 文档
*.md
LICENSE
SECURITY.md
CONTRIBUTING.md

# 测试文件
*_test.go
testdata/
coverage.txt
*.test

# 配置文件（敏感信息）
.env
.env.*
*.sample
*.example

# 临时文件
tmp/
temp/
*.tmp
*.log
*.swp
*.swo
*~

# IDE 配置
.vscode/
.idea/
*.iml
.DS_Store

# 构建产物（由 Go 自动生成）
bin/
dist/

# 依赖目录（Go modules 会自动下载）
vendor/

# 其他不需要的文件
Makefile
scripts/
