# Server Configuration
PORT=8080
GIN_MODE=debug

# Hunyuan LLM Configuration (用于自动标签生成)
# 获取地址: https://console.cloud.tencent.com/hunyuan
HUNYUAN_API_KEY=your_hunyuan_api_key_here
HUNYUAN_MODEL=hunyuan-lite
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1

# GitHub OAuth Configuration
# 从 GitHub OAuth App 获取: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
# 开发环境回调地址
GITHUB_REDIRECT_URI=http://localhost:8080/api/v1/auth/callback

# Session Configuration
# 生成随机密钥: openssl rand -base64 32
SESSION_SECRET=your_random_session_secret_here
SESSION_SECURE=false
# Session 过期时间（小时）
SESSION_MAX_AGE=24

# Token Encryption Configuration
# 生成随机密钥: openssl rand -base64 32
ENCRYPTION_KEY=your_random_encryption_key_here

# Frontend Configuration
# 开发环境前端地址
FRONTEND_URL=http://localhost:3000

# Database Configuration (可选，暂时使用内存存储)
# DATABASE_URL=postgres://user:password@localhost:5432/stars_manager?sslmode=disable
